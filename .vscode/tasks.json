{
    "tasks": [
        {
            "type": "cppbuild",
            "label": "C/C++: cl.exe 生成 DLL (Release x64)",
            "command": "cl.exe",
            "args": [
                "/LD",
                "/MD",
                "/O2",
                "/Zi",                          // 保留调试符号（可选）
                "/EHsc",
                "/nologo",
                "/std:c++17", 
                "/utf-8",
                "/DUNICODE",
                "/D_UNICODE",
                "/Fe${workspaceFolder}\\x64\\release\\MijiaPower_1.dll",  // DLL 输出
                "/Fo${workspaceFolder}\\x64\\release\\intermediate\\",        // .obj 进子文件夹
                "/Fd${workspaceFolder}\\x64\\release\\intermediate\\",        // .pdb 进子文件夹


                "/Iinclude",
                "src\\*.cpp",
                "src\\device\\*.cpp",
                "src\\mijiapower\\*.cpp",
                "src\\win32dialog\\*.cpp",









            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": ["$msCompile"],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        }
    ],
    "version": "2.0.0"
}